{
  "name": "vterm.js",
  "version": "0.4.0",
  "description": "Modern terminal emulator — full VT/ECMA-48/xterm standards coverage. Pure TypeScript, zero dependencies.",
  "keywords": [
    "ansi",
    "ecma-48",
    "headless",
    "terminal-emulator",
    "tui",
    "typescript",
    "vt",
    "vterm",
    "xterm",
    "zero-dependency"
  ],
  "homepage": "https://github.com/beorn/vterm/tree/main/packages/vterm",
  "bugs": "https://github.com/beorn/vterm/issues",
  "license": "MIT",
  "author": "Bjørn Stabell",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/vterm.git",
    "directory": "packages/vterm"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "node": ">=23.6.0"
  }
}
